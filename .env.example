# base_url = os.getenv("AIGW_BASE_URL", "https://aigw.netease.com/v1")
# default_model = os.getenv("DEFAULT_MODEL", "claude-sonnet-4-6")
# 
# # 使用配置
# client = OpenAI(
#     base_url=base_url,
#     api_key=api_key
# )
#
# ========================================
# JavaScript 示例代码
# ========================================
#
# import dotenv from 'dotenv';
# 
# dotenv.config();
# 
# const apiKey = process.env.AIGW_API_KEY;
# const baseUrl = process.env.AIGW_BASE_URL || 'https://aigw.netease.com/v1';
#
# ========================================

# ========================================
# 快速开始命令
# ========================================
#
# 安装依赖：
# Python: pip install python-dotenv openai
# Node.js: npm install dotenv openai
#
# 运行示例：
# python example.py
# node example.js
#
# ========================================
