# ========================================
# 网易 AIGW 环境变量配置模板
# ========================================
# 使用方法：
# 1. 复制此文件为 .env
# 2. 填入你的实际凭证
# 3. 在代码中加载环境变量
# ========================================

# ========================================
# 必需配置
# ========================================

# AIGW API 凭证
# 格式：{APP_ID}.{APP_KEY}
# 示例：abc123def456.ghi789jkl012
AIGW_API_KEY=your_app_id.your_app_key

# ========================================
# 可选配置
# ========================================

# API 基础 URL（通常不需要修改）
AIGW_BASE_URL=https://aigw.netease.com/v1
AIGW_BASE_URL_INT=https://aigw-int.netease.com/v1

# ========================================
# 认证配置（高级）
# ========================================

# 如果使用 Access Key + Secret Key 认证
# AIGW_ACCESS_KEY=your_access_key
# AIGW_SECRET_KEY=your_secret_key

# 如果使用 Bearer Token 认证
# AIGW_BEARER_TOKEN=your_bearer_token

# ========================================
# 模型配置
# ========================================

# 默认使用的模型
DEFAULT_MODEL=claude-sonnet-4-6

# 推理专用模型
REASONING_MODEL=claude-opus-4-6

# 快速响应模型
FAST_MODEL=claude-haiku-4-6

# 成本优化模型
COST_EFFECTIVE_MODEL=deepseek-chat

# 大上下文模型
LONG_CONTEXT_MODEL=gemini-1-5-pro

# ========================================
# 性能配置
# ========================================

# 最大重试次数
MAX_RETRIES=3

# 重试延迟（秒）
RETRY_DELAY=1

# 请求超时（秒）
REQUEST_TIMEOUT=60

# 是否启用流式输出
STREAMING_ENABLED=true

# 最大输出 tokens
MAX_TOKENS=4000

# 温度参数（0-2）
TEMPERATURE=0.7

# ========================================
# 成本控制
# ========================================

# 预算限制（每分钟，单位：积分）
BUDGET_PER_MINUTE=100

# 单个请求最大成本限制
MAX_COST_PER_REQUEST=10

# 警告阈值（百分比）
WARNING_THRESHOLD=80

# ========================================
# 限流配置
# ========================================

# 最大并发请求数
MAX_CONCURRENCY=5

# 请求间隔（毫秒）
REQUEST_INTERVAL=1000

# RPM 限制
RPM_LIMIT=60

# ========================================
# 日志配置
# ========================================

# 日志级别：debug, info, warning, error
LOG_LEVEL=info

# 是否保存 API 调用日志
SAVE_API_LOGS=true

# 日志文件路径
LOG_FILE_PATH=./logs/aigw.log

# ========================================
# Webhook 配置（高级）
# ========================================

# Webhook URL（用于接收异步通知）
WEBHOOK_URL=https://your-server.com/webhook

# Webhook 密钥（用于验证）
WEBHOOK_SECRET=your_webhook_secret

# ========================================
# Python 示例代码
# ========================================
# 
# from dotenv import load_dotenv
# import os
# 
# # 加载环境变量
# load_dotenv()
# 
# # 获取配置
